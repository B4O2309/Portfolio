{
  "name": "pflo-backend",
  "version": "1.0.0",
  "description": "Portfolio backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "db:generate": "prisma generate --schema src/prisma/schema.prisma",
    "db:seed": "tsx src/prisma/seed.ts",
    "db:studio": "prisma studio --schema src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "marked": "^12.0.0",
    "nodemailer": "^6.9.13",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "prisma": "^5.14.0",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5"
  }
}
